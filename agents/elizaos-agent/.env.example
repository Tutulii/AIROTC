# AIR OTC ElizaOS Agent Configuration

# LLM provider key. Optional for deterministic demo fallback, required for live LLM text generation.
GROQ_API_KEY=your_groq_api_key_here

# Solana and AIR OTC services
SOLANA_RPC_URL=https://api.devnet.solana.com
AIROTC_API_URL=http://localhost:3000
AIROTC_WS_URL=ws://localhost:8080

# Devnet demo wallets. Never commit real private keys.
SELLER_PRIVATE_KEY=base58_or_json_array_secret_key
BUYER_PRIVATE_KEY=base58_or_json_array_secret_key

# Demo trade settings
AIROTC_TRADE_PRICE_SOL=0.001
AIROTC_TRADE_COLLATERAL_SOL=0.001
AIROTC_TRADE_AMOUNT=1

# Full-pipeline demo gates
AIROTC_REQUIRE_ZERION=true
AIROTC_ZERION_ONLINE_CHECK_MODE=light
AIROTC_REQUIRE_FULL_UMBRA=true
UMBRA_SETTLEMENT_LIFECYCLE_MODE=FULL_UMBRA
AIROTC_REQUIRE_TORQUE_EVIDENCE=true
