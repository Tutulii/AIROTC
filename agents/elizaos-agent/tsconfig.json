{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "index.ts",
    "character.ts",
    "plugins/**/*.ts",
    "providers/**/*.ts",
    "services/**/*.ts",
    "proof/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "actions/**/*"]
}
