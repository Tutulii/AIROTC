# ═══════════════════════════════════════════════════════
# AgentOTC API Server — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/agentotc"

# Middleman Agent URL (for forwarding matched deals)
MIDDLEMAN_URL=http://localhost:8080

# HMAC Bridge Secret (shared with middleman)
BRIDGE_SECRET=your-bridge-secret-here

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Solana (for on-chain event listener)
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=Hp6RbB21KrKQEaKvqAZPLHYYVDFKNJaiRtzE1494dpmx
