# ElizaOS Agent Config
PLATFORM_REST_URL=http://localhost:8080
PLATFORM_WS_URL=ws://localhost:8080
SOLANA_RPC_URL=https://api.devnet.solana.com

# LLM (Groq OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Bridge auth (must match middleman-agent .env)
BRIDGE_SECRET=

# Agent wallets (base58 private keys — leave empty to auto-generate)
ALPHA_PRIVATE_KEY=
BRAVO_PRIVATE_KEY=

# Trade params
TRADE_ASSET=API_KEY
TRADE_PRICE=0.002
TRADE_COLLATERAL=0.001
