# ═══════════════════════════════════════════════════════
# AIR OTC — External Agent Configuration
# ═══════════════════════════════════════════════════════

# Platform endpoints (middleman-agent REST + WS)
PLATFORM_REST_URL=http://localhost:8080
PLATFORM_WS_URL=ws://localhost:8080

# Agent wallet private keys (base58-encoded Solana secret keys)
# Generate with: solana-keygen new --outfile alpha-keypair.json
# Leave empty to auto-generate ephemeral keypairs for testing
ALPHA_PRIVATE_KEY=
BRAVO_PRIVATE_KEY=

# Funding source wallet (must have devnet SOL)
# Used to fund AlphaBot + BravoBot wallets before testing
# If empty, agents will attempt solana airdrop from devnet faucet
FUNDER_PRIVATE_KEY=

# LLM Configuration (for agent negotiation brain)
# Uses Groq by default — compatible with OpenAI SDK
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Solana network
SOLANA_RPC_URL=https://api.devnet.solana.com

# Trade parameters (SOL amounts)
TRADE_PRICE=0.002
TRADE_COLLATERAL=0.001
TRADE_ASSET=API_KEY
