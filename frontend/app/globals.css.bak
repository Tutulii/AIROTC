@import "tailwindcss";

/* =============================================
   AgentOTC — Tactical Observatory Design System
   ============================================= */

@theme inline {
  /* Backgrounds */
  --color-bg-root: #06090F;
  --color-bg-surface: #10131a;
  --color-bg-elevated: #131720;
  --color-bg-card: #191c22;
  --color-bg-card-hover: #1d2026;
  --color-bg-highest: #272a31;
  --color-bg-bright: #32353c;
  --color-bg-input: #0F1420;

  /* Primary Accent - Teal */
  --color-accent: #46f1c5;
  --color-accent-dim: #28dfb5;
  --color-accent-muted: #00d4aa;
  --color-accent-bg: rgba(70, 241, 197, 0.1);
  --color-accent-glow: rgba(70, 241, 197, 0.06);

  /* Secondary - Blue */
  --color-secondary: #adc6ff;
  --color-secondary-solid: #3B82F6;
  --color-secondary-container: #0566d9;

  /* Semantic */
  --color-success: #10B981;
  --color-error: #EF4444;
  --color-warning: #F59E0B;
  --color-info: #3B82F6;

  /* Tier Colors */
  --color-tier-elite: #F5C842;
  --color-tier-trusted: #46f1c5;
  --color-tier-verified: #10B981;
  --color-tier-neutral: #64748B;

  /* Text */
  --color-text-primary: #e1e2eb;
  --color-text-secondary: #8B9AB8;
  --color-text-muted: #64748B;
  --color-text-disabled: #3A4558;

  /* Borders */
  --color-border: #2A3042;
  --color-border-subtle: rgba(42, 48, 66, 0.4);

  /* Font families */
  --font-headline: 'Space Grotesk', system-ui, sans-serif;
  --font-body: 'Inter', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
}

/* Base */
body {
  background: var(--color-bg-surface);
  color: var(--color-text-primary);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection {
  background: var(--color-accent);
  color: #00382b;
}

/* Material Symbols */
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}

/* Animations */
@keyframes pulse-glow {

  0%,
  100% {
    opacity: 0.6;
    transform: scale(1);
  }

  50% {
    opacity: 1;
    transform: scale(1.1);
  }
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slide-in-right {
  from {
    opacity: 0;
    transform: translateX(20px);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}

.pulse-glow {
  animation: pulse-glow 2s infinite ease-in-out;
}

.animate-fade-in-up {
  animation: fade-in-up 0.5s ease-out;
}

.animate-slide-in {
  animation: slide-in-right 0.3s ease-out;
}

.skeleton {
  background: linear-gradient(90deg, var(--color-bg-highest) 25%, #2A3042 50%, var(--color-bg-highest) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite ease-in-out;
  border-radius: 4px;
}

/* Grid Lines Pattern */
.grid-lines {
  background-image:
    linear-gradient(to right, var(--color-border) 1px, transparent 1px),
    linear-gradient(to bottom, var(--color-border) 1px, transparent 1px);
  background-size: 40px 40px;
}

/* Animated gradient flow — for deal state machine connectors */
@keyframes gradient-flow {
  0% {
    background-position: 0% 50%;
  }

  50% {
    background-position: 100% 50%;
  }

  100% {
    background-position: 0% 50%;
  }
}

.gradient-flow {
  background: linear-gradient(90deg, var(--color-accent), var(--color-secondary-solid), var(--color-accent));
  background-size: 200% 100%;
  animation: gradient-flow 3s ease infinite;
}

@keyframes scale-in {
  from {
    opacity: 0;
    transform: scale(0.92);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

.animate-scale-in {
  animation: scale-in 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Card hover lift — reusable utility */
.card-hover-lift {
  transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
}

.card-hover-lift:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(70, 241, 197, 0.06);
}

.card-hover-lift:active {
  transform: translateY(0);
}

/* Custom Scrollbar */
.custom-scrollbar::-webkit-scrollbar {
  width: 4px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: 2px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: var(--color-text-muted);
}

/* Firefox scrollbar */
.custom-scrollbar {
  scrollbar-width: thin;
  scrollbar-color: var(--color-border) transparent;
}

/* ─── Responsive: wider container on large desktops ─── */
@media (min-width: 1440px) {
  .max-w-7xl {
    max-width: 1400px;
  }
}

@media (min-width: 1920px) {
  .max-w-7xl {
    max-width: 1680px;
  }
}

/* Reduced motion — accessibility */
@media (prefers-reduced-motion: reduce) {

  .pulse-glow,
  .animate-fade-in-up,
  .animate-slide-in,
  .skeleton {
    animation: none !important;
  }

  /* Suppress Tailwind animate-pulse */
  .animate-pulse {
    animation: none !important;
  }

  /* Remove transitions globally */
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* Focus visible indicators for keyboard navigation */
:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

/* Skip to content link (screen-reader first, visible on focus) */
.skip-nav {
  position: absolute;
  top: -100%;
  left: 16px;
  z-index: 9999;
  padding: 8px 16px;
  background: var(--color-accent);
  color: #00382b;
  font-weight: 700;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.skip-nav:focus {
  top: 8px;
}
