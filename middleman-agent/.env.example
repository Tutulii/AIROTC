# Solana RPC endpoint (devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Escrow program ID deployed on devnet
PROGRAM_ID=Hp6RbB21KrKQEaKvqAZPLHYYVDFKNJaiRtzE1494dpmx

# Agent wallet private key (base58-encoded)
# Generate with: solana-keygen new --outfile agent-keypair.json
# Then base58-encode the secret key bytes
PRIVATE_KEY=

# Agent heartbeat interval in milliseconds
HEARTBEAT_INTERVAL_MS=5000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# LLM API key (Groq or OpenAI-compatible)
# Get one at: https://console.groq.com/keys
OPENAI_API_KEY=gsk_...

# LLM Configuration
# Base URL for OpenAI-compatible API
LLM_BASE_URL=https://api.groq.com/openai/v1
# Known working Groq models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# Use "llama-3.3-70b-versatile" for best quality, "llama-3.1-8b-instant" for speed
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_FAST=llama-3.1-8b-instant
LLM_MODEL_DEEP=llama-3.3-70b-versatile
LLM_MODEL_JUDGE=llama-3.3-70b-versatile

# PostgreSQL connection string (for persistent storage)
# Local: postgresql://USER:PASSWORD@localhost:5432/DB
# Supabase: postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Shared HMAC secret for internal bridge traffic (api-server <-> middleman-agent
# and observatory sync writes). Must match the api-server value exactly.
BRIDGE_SECRET=

# Observatory mirror base URL for signed internal sync writes.
OBSERVATORY_API_URL=http://localhost:3000

# Optional: IDL path override (needed for Docker deployment)
# IDL_PATH=/app/escrow.json

# Dune SIM — On-Chain Analytics (Track 2: Dune SIM Hackathon)
# Get your API key at: https://sim.dune.com → Keys
DUNE_SIM_API_KEY=sim_your_api_key_here

# Zerion — Superteam autonomous agent track
# The demo path uses Zerion CLI + live API as a pre-trade gate. On devnet,
# keep the default light online check; strict wallet portfolio verification is
# mainnet-oriented and should only be enabled with a Zerion-visible wallet.
ZERION_API_KEY=
ZERION_API_BASE=https://api.zerion.io/v1
ZERION_API_BASE_URL=https://api.zerion.io/v1
ZERION_VERIFICATION_MODE=hybrid
AIROTC_REQUIRE_ZERION=true
AIROTC_ZERION_ALLOW_OFFLINE=false
AIROTC_ZERION_CHAIN=solana
AIROTC_ZERION_ONLINE_CHECK_MODE=light
AIROTC_ZERION_VERIFY_TRADE_WALLETS=false
# Optional wallet used only for the live Zerion API gate. If omitted, the
# proof falls back to the trade wallet; no private key is needed for this.
AIROTC_ZERION_PROOF_WALLET=
# Stronger demo evidence: provide a Zerion/agent-token transaction hash, or set
# AIROTC_ZERION_EXECUTE_REAL_TX=true with a funded trading wallet configuration.
AIROTC_ZERION_EXTERNAL_TX=
AIROTC_ZERION_REQUIRE_REAL_TX=false
AIROTC_ZERION_EXECUTE_REAL_TX=false
AIROTC_ZERION_FROM_TOKEN=SOL
AIROTC_ZERION_TO_TOKEN=USDC
AIROTC_ZERION_TX_AMOUNT=0.0001

# Track 6: Encrypt (FHE) — Confidential Escrow
# Encrypt program on Solana devnet (pre-alpha)
ENCRYPT_PROGRAM_ID=ENcR3kPU6MNM1VTH2LxYdGM2UR2FjisKSbJWhHsuPMz
# Encrypt gRPC endpoint for FHE ciphertext operations
ENCRYPT_GRPC_URL=https://pre-alpha-dev-1.encrypt.ika-network.net:443
# Enable confidential escrow flow (feature flag)
# Required for strict PER and the unified ER/PER confidential settlement path.
ENABLE_CONFIDENTIAL_ESCROW=true
# Optional dedicated 32-byte key for sealing PER execution terms at rest.
# If omitted, the agent derives the sealing key from the operator wallet secret.
# PRIVATE_EXECUTION_TERMS_KEY may be base64 (32 raw bytes) or 64 hex chars.
PRIVATE_EXECUTION_TERMS_KEY=

# Track 6: Ika (dWallet) — Autonomous Cross-Chain Signing
# dWallet program on Solana devnet (pre-alpha)
DWALLET_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
# Ika gRPC endpoint for DKG/Sign operations
IKA_GRPC_URL=pre-alpha-dev-1.ika.ika-network.net:443
# Curve: 0=Secp256k1(ETH), 1=Secp256r1(WebAuthn), 2=Curve25519(Solana), 3=Ristretto
DWALLET_CURVE=2
# Scheme: 0=EcdsaKeccak256, 1=EcdsaSha256, 5=EddsaSha512(Solana), 6=SchnorrkelMerlin
DWALLET_SIGNATURE_SCHEME=5
# Gas deposit init strategy: detect_only | create | require_create
IKA_GAS_DEPOSIT_MODE=detect_only

# Confidential release policy
# Devnet default is short for fast end-to-end verification; mainnet should be longer.
RELEASE_DISPUTE_WINDOW_SECONDS=15

# Strict PER privacy mode
# When enabled, the middleman must continue PER deals from opaque handoff proof,
# hashes, ciphertext handles, and funding commitments only.
PER_STRICT_OPAQUE_MODE=true
PER_FUNDING_PRIVACY_TIER=SHIELDED_CREDIT
PER_ALLOW_DIRECT_SOL_UNSAFE=false

# Full Umbra payout lifecycle
# Strict PER defaults to FULL_UMBRA in code. Keep these explicit for operators
# and demo runners so the server, SDK agents, and proofs agree on the same gate.
UMBRA_SETTLEMENT_LIFECYCLE_MODE=FULL_UMBRA
AIROTC_REQUIRE_FULL_UMBRA=true
AIROTC_UMBRA_UTXO_MODE=SELF_CLAIMABLE
# Devnet must use the devnet Umbra services. The code also defaults these by
# network and fails fast if an official mainnet endpoint is mixed into devnet.
UMBRA_INDEXER_API_ENDPOINT=https://utxo-indexer.api-devnet.umbraprivacy.com
UMBRA_RELAYER_API_ENDPOINT=https://relayer.api-devnet.umbraprivacy.com

# Legacy Umbra 5-phase settlement lifecycle
# Keep disabled for the production confidential route. Even if enabled, the
# code only honors it in test mode so it cannot become a production shortcut.
ENABLE_LEGACY_UMBRA_STEALTH_LIFECYCLE=false

# Demo / simulation routes
# Keep disabled in production. These routes are only for local demos and tests.
ENABLE_SIMULATION_ROUTES=false

# Demo runtime listeners
# Keep disabled in production. These synthetic listeners may only run in test
# mode or explicitly enabled demo environments.
ALLOW_DEMO_RUNTIME_LISTENERS=false

# Torque MCP / custom event ingestion
# Docs-only integration: AIR OTC emits post-settlement participant events and
# Torque handles recurring incentives on its normal cadence.
ENABLE_TORQUE_EVENTS=false
TORQUE_INGEST_URL=https://ingest.torque.so/events
TORQUE_EVENT_API_KEY=
TORQUE_REQUEST_TIMEOUT_MS=8000
TORQUE_RETRY_BASE_MS=5000
TORQUE_RETRY_MAX_MS=60000
TORQUE_RETRY_POLL_MS=10000
ER_PLATFORM_FEE_BPS=100
PER_PLATFORM_FEE_BPS=110
ER_REWARD_SHARE_OF_FEE_BPS=1000
PER_REWARD_SHARE_OF_FEE_BPS=1200

# IMPORTANT: Run the devnet init script before first start:
# npx ts-node scripts/initDevnet.ts
